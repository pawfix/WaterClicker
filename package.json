{
  "name": "waterclicker",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electronmon ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "sass": "^1.99.0"
  },
  "build": {
    "appId": "com.waterclicker.pawfix",
    "npmRebuild": false,
    "productName": "WaterClicker",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "zip"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
